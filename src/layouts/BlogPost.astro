---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, author, isPillar } = Astro.props;

const pubDateStr = pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedDateStr = updatedDate?.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
			author={author}
		/>
	</head>

	<body>
		<Header />
		<main>
			<nav class="breadcrumb" aria-label="パンくずリスト">
				<a href="/">ホーム</a>
				<span class="sep">›</span>
				<a href="/blog/">記事一覧</a>
				{category && (
					<>
						<span class="sep">›</span>
						<a href={`/category/${category}/`}>{category}</a>
					</>
				)}
				<span class="sep">›</span>
				<span>{title}</span>
			</nav>

			<article>
				<header class="post-header">
					<div class="post-meta">
						{category && <a href={`/category/${category}/`} class="category-badge">{category}</a>}
						{isPillar && <span class="pillar-badge">まとめ記事</span>}
					</div>
					<h1 class="post-title">{title}</h1>
					<p class="post-desc">{description}</p>
					<div class="post-meta">
						<span class="post-date">公開日：{pubDateStr}</span>
						{updatedDate && (
							<span class="post-date">更新日：{updatedDateStr}</span>
						)}
					</div>
				</header>

				{heroImage && (
					<img
						class="post-hero"
						src={heroImage}
						alt={title}
						style="max-width:100%;border-radius:8px;margin:1em 0;"
					/>
				)}

				<div class="prose">
					<slot />
				</div>

				<!-- アフィリエイトCTA（記事末尾） -->
				{category === 'シロアリ駆除' ? (
					<div class="affiliate-box">
						<p class="affiliate-lead">🏠 シロアリの被害が心配な方へ。まずは無料見積もりを。</p>
						<a href="https://px.a8.net/svt/ejp?a8mat=4B3MEP+BRWPT6+39GM+HV7V6" rel="nofollow" target="_blank" class="affiliate-btn btn-primary">
							今すぐシロアリ110番に無料相談する →
						</a>
						<img border="0" width="1" height="1" src="https://www10.a8.net/0.gif?a8mat=4B3MEP+BRWPT6+39GM+HV7V6" alt="" />
						<a href="https://px.a8.net/svt/ejp?a8mat=4B3MEP+BRBA7E+39GM+5AIXAQ" rel="nofollow" target="_blank" class="affiliate-btn btn-secondary">
							害虫駆除110番でも相談する →
						</a>
						<img border="0" width="1" height="1" src="https://www14.a8.net/0.gif?a8mat=4B3MEP+BRBA7E+39GM+5AIXAQ" alt="" />
					</div>
				) : (
					<div class="affiliate-box">
						<p class="affiliate-lead">🔍 すぐに業者を呼びたい方はこちら。24時間365日対応。</p>
						<a href="https://px.a8.net/svt/ejp?a8mat=4B3MEP+BRBA7E+39GM+5AIXAQ" rel="nofollow" target="_blank" class="affiliate-btn btn-primary">
							今すぐ害虫駆除110番に無料相談する →
						</a>
						<img border="0" width="1" height="1" src="https://www14.a8.net/0.gif?a8mat=4B3MEP+BRBA7E+39GM+5AIXAQ" alt="" />
						<a href="https://px.a8.net/svt/ejp?a8mat=4B3MEP+BQPULM+36X8+HV7V6" rel="nofollow" target="_blank" class="affiliate-btn btn-secondary">
							害虫駆除屋でも見積もりを取る →
						</a>
						<img border="0" width="1" height="1" src="https://www16.a8.net/0.gif?a8mat=4B3MEP+BQPULM+36X8+HV7V6" alt="" />
					</div>
				)}

				<div class="author-box">
					<div class="author-icon">🏠</div>
					<div>
						<div class="author-name">{author ?? '害虫・害獣駆除ナビ編集部'}</div>
						<div class="author-bio">
							家まわりの害虫・害獣トラブルを主夫目線で調査・執筆しています。
							掲載情報は公開時点のものです。最新情報は各公式サイトでご確認ください。
						</div>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
